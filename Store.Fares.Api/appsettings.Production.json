{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_DB_SERVER;Database=Store.Fares.App;User Id=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;Encrypt=true;TrustServerCertificate=false;",
    "Redis": "YOUR_REDIS_CONNECTION_STRING"
  },
  "BaseUrl": "https://YOUR_DOMAIN.com",
  "jwtOptions": {
    "SecretKey": "CHANGE_THIS_TO_A_SECURE_SECRET_KEY_WITH_AT_LEAST_32_CHARACTERS!",
    "Audience": "StoreFaresApp",
    "Issuer": "StoreFares",
    "DurationInDays": 7
  }
}
